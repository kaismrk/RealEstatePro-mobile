EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_DEFAULT_COUNTRY=TN
EXPO_PUBLIC_MAPS_PROVIDER=apple

# Google OAuth — create clients at console.cloud.google.com
# iOS  → iOS client (bundle ID com.hovioo.app)
# Android → Android client (package com.hovioo.app + SHA-1 of your keystore)
# Web  → Web client (used for id_token exchange on the backend)
# If absent, the Google sign-in button is hidden via feature flag.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
