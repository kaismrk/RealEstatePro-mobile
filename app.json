{
  "expo": {
    "name": "Hovioo",
    "slug": "RealEstatePro-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "realestatepro",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5f09fe"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hovioo.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Show properties near you",
        "NSCameraUsageDescription": "Take photos of your property",
        "NSPhotoLibraryUsageDescription": "Select photos for your listing",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hovioo.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "PLACEHOLDER_KEY_SET_IN_EAS"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5f09fe"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b3860b3d-7c8c-40ab-bf23-4cbb316eae88"
      }
    },
    "owner": "kaismrk81"
  }
}
